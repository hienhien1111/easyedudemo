# .env.production.example
# Copy file này sang .env.production trên server và điền giá trị thật
# KHÔNG commit .env.production lên git

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
POSTGRES_DB=eedemo_db
POSTGRES_USER=eedemo
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_PORT=5434

# DATABASE_URL dùng service name "postgres" (Docker internal DNS)
DATABASE_URL="postgresql://eedemo:CHANGE_ME_strong_password_here@postgres:5432/eedemo_db?schema=public"

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_random_64char_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=CHANGE_ME_another_random_64char_string
JWT_REFRESH_EXPIRES=7d

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=3001
FRONTEND_PORT=3000

# URL mà browser của user có thể truy cập backend
# Thay localhost bằng IP/domain của server nếu deploy lên VPS thật
NEXT_PUBLIC_API_URL=http://localhost:3001/api
